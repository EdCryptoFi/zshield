# ── ZShield environment variables ──────────────────────────────────────────
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to git.

# NextAuth / Auth.js secret — generate with: openssl rand -base64 32
AUTH_SECRET=

# Full URL of the app (no trailing slash)
# Local: http://localhost:3000
# Production: https://zshield.vercel.app
NEXTAUTH_URL=http://localhost:3000

# Internal OIDC signing secret — generate with: openssl rand -base64 32
ZCASHAUTH_SECRET=

# Optional: Redis connection string for production nonce store
# If not set, uses in-memory store (fine for single-instance deployments)
# REDIS_URL=redis://...
